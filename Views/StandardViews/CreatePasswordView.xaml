<UserControl x:Class="GearFix.Views.CreatePasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GearFix.Views"
             mc:Ignorable="d">
    <Border Height="600" Width="500" Background="{StaticResource MainBack}"
            CornerRadius="15" Padding="10" BorderBrush="{StaticResource HeaderBack}" BorderThickness="5"
            IsHitTestVisible="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="0.2*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="0.2*"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" FontSize="30" HorizontalAlignment="Stretch"
                       VerticalAlignment="Center"
                       FontWeight="Bold"
                       Foreground="{StaticResource HeaderText}"
                       TextAlignment="Center">Придумайте пароль</TextBlock>
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock FontSize="20" Margin="3" Foreground="{StaticResource HeaderText}">Введите пароль</TextBlock>
                <TextBox FontSize="20" Margin="3" TabIndex="1" Padding="3" Text="{Binding TextBoxPassword, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock FontSize="20" Margin="3" Foreground="{StaticResource HeaderText}">Повторите пароль</TextBlock>
                <TextBox FontSize="20" Margin="3" Padding="3" TabIndex="2" Text="{Binding TextBoxRepeatPassword, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="{Binding ErrorMessage}" FontSize="20" Margin="5 25"
                           Foreground="{StaticResource ErrorColor}" TextWrapping="Wrap"
                           MinHeight="100"/>

                <Border Background="{StaticResource SurfaceBack}" Margin="10 0" Padding="10" BorderThickness="3"
                        BorderBrush="{StaticResource BorderBrush}" CornerRadius="15">
                    <TextBlock Foreground="{StaticResource HeaderText}" FontSize="16" TextWrapping="Wrap">Пароль необходимо запомнить, вы будете вводить его при кажодм входе в приложение!</TextBlock>
                    <Border.Effect>
                        <DropShadowEffect Color="#000" Opacity="0.4" BlurRadius="20"/>
                    </Border.Effect>
                </Border>
            </StackPanel>
            <Button Grid.Row="3" IsDefault="True" Background="{StaticResource ButtonBack}" MaxHeight="70" MaxWidth="210"
                    Content="Создать" Foreground="{StaticResource MainText}" FontWeight="Bold"
                    Command="{Binding CreatePasswordCommand}"
                    FontSize="20">
                <Button.Effect>
                    <DropShadowEffect Color="#000" Opacity="0.3" BlurRadius="20" />
                </Button.Effect>
            </Button>
        </Grid>
        <Border.Effect>
            <DropShadowEffect Color="#000" Opacity="0.4" BlurRadius="30" Direction="235"/>
        </Border.Effect>
    </Border>
</UserControl>
