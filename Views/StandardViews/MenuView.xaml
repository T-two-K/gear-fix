<UserControl x:Class="GearFix.Views.MenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GearFix.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#0F1117"
                BorderBrush="#1E2435"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,28,20,24">
                    <TextBlock Text="⚙ GearFix"
                               Foreground="#5CCCCC"
                               FontSize="22"
                               FontWeight="Bold"/>
                    <TextBlock Text="Диагностика автомобилей"
                               Foreground="#5A6279"
                               FontSize="11"
                               Margin="2,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="12,0">

                    <Button Content="🔧  Диагностика"
                            HorizontalContentAlignment="Left"
                            Padding="14,12"
                            Margin="0,2"
                            Command="{Binding NavigateDiagnosticsCommand}"/>

                    <Button Content="⛽  Найти СТО на карте"
                            HorizontalContentAlignment="Left"
                            Padding="14,12"
                            Margin="0,2"
                            Command="{Binding NavigateToMapCommand}"/>

                    <Button Content="⚙  Настройки"
                            HorizontalContentAlignment="Left"
                            Padding="14,12"
                            Margin="0,2"
                            Command="{Binding NavigateSettingsCommand}"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="12,0,12,20">
                    <Button Content="＋  Добавить машину"
                            Padding="14,12"
                            Margin="0,0,0,12"
                            Command="{Binding AddCarCommand}"/>

                    <TextBlock Text="v1.0.0"
                               Foreground="#5A6279"
                               FontSize="10"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#0F1117">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#0F1117"
                    BorderBrush="#1E2435"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <TextBlock Text="Мои машины"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#EAEAEA"
                               VerticalAlignment="Center"/>

                    <TextBlock HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="#5A6279"
                               FontSize="12">
                        <Run Text="Транспортов: "/>
                        <Run Text="{Binding Cars.Count, Mode=OneWay}"
                             Foreground="#5CCCCC"/>
                    </TextBlock>
                </Grid>
            </Border>

            <Grid Grid.Row="1">

                <ListBox ItemsSource="{Binding Cars}"
                         SelectedItem="{Binding SelectedCar}"
                             Padding="12"
                             x:Name="CardsListBox"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel></WrapPanel>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="6"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Height="310"
                                    Cursor="Hand"
                                        CornerRadius="10"
                                        Background="#161B27"
                                        BorderBrush="#1E2435"
                                        BorderThickness="1"
                                        RenderTransformOrigin="0.5,0.5"
                                        Width="{Binding ActualWidth,
                                            RelativeSource={RelativeSource AncestorType=WrapPanel},
                                            Converter={StaticResource CardWidthConv}}"
                                        MinWidth="250">

                                <Border.Effect>
                                    <DropShadowEffect x:Name="CardShadow"
                                          Color="#000000"
                                          BlurRadius="10"
                                          ShadowDepth="3"
                                          Opacity="0.35"/>
                                </Border.Effect>

                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="CardTranslate" Y="0"/>
                                </Border.RenderTransform>

                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Border.MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     To="-6" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="20" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.6" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="Border.MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                     Storyboard.TargetProperty="Y"
                                                     To="0" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="BlurRadius"
                                                     To="10" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.35" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="140"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                                CornerRadius="10,10,0,0"
                                                Background="{StaticResource SurfaceBack2}"
                                                ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="🚗"
                                                           Foreground="{StaticResource ClueBack}"
                                                           FontSize="40"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Opacity="0.5"/>
                                            <Image Source="{Binding ImagePath, Converter={StaticResource ImageConv}}"
                                                       Stretch="UniformToFill" VerticalAlignment="Stretch"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="14 12 14 12" VerticalAlignment="Bottom">

                                        <TextBlock FontSize="15"
                                                       FontWeight="SemiBold"
                                                       Foreground="#EAEAEA">
                                                <Run Text="{Binding Make}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding Model}"/>
                                        </TextBlock>

                                        <TextBlock FontSize="12"
                                                       Foreground="#5A6279"
                                                       Margin="0,3,0,8">
                                                <Run Text="{Binding Year}"/>
                                                <Run Text=" · "/>
                                                <Run Text="{Binding Mileage}"/>
                                                <Run Text=" км"/>
                                        </TextBlock>

                                        <Border CornerRadius="4"
                                                    Padding="8,3"
                                                    Background="Transparent"
                                                    BorderBrush="#009999"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Left"
                                                    Margin="0,0,0,12"
                                                    Visibility="{Binding EngineType,
                                                        Converter={StaticResource NullToVis}}">
                                            <TextBlock Text="{Binding EngineType}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#5CCCCC"/>
                                        </Border>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                        Content="✏ Изменить"
                                                        FontSize="11"
                                                        Padding="0,7"
                                                        Command="{Binding DataContext.EditCarCommand,
                                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"/>

                                            <Button Grid.Column="2"
                                                        Content="🗑 Удалить"
                                                        FontSize="11"
                                                        Padding="0,7"
                                                        Style="{StaticResource DeleteButton}"
                                                        Command="{Binding DataContext.DeleteCarCommand,
                                                            RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="MapLoadingOverlay"
                        Background="Transparent"
                        Visibility="{Binding IsEmpty,
                            Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="🚘"
                                   Foreground="{StaticResource ClueBack}"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"
                                   Opacity="0.5"/>
                        <TextBlock Text="Список машин пуст"
                                   FontSize="14"
                                   Foreground="#5A6279"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
