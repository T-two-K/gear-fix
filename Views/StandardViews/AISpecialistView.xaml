<UserControl x:Class="GearFix.Views.AISpecialistView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GearFix.Views"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource HeaderBack}"
                BorderBrush="#8B3E00"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="20,24,20,16">
                    <TextBlock Text="🔧 Диагностика"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Анализ на основе ИИ"
                               Foreground="White"
                               Opacity="0.45"
                               FontSize="11"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <Border Grid.Row="1"
                        Margin="12,0,12,16"
                        CornerRadius="12"
                        Background="{StaticResource SurfaceBack2}"
                        Padding="14,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="ТЕКУЩАЯ МАШИНА"
                                   Foreground="{StaticResource HeaderText}"
                                   Opacity="0.5"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>

                        <StackPanel Grid.Row="1"
                                    Visibility="{Binding SelectedCar, Converter={StaticResource NullToVis}}">
                            <TextBlock FontSize="16" FontWeight="Bold" Foreground="White">
                                <Run Text="{Binding SelectedCar.Model}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding SelectedCar.Make}"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="White" Opacity="0.6" Margin="0,3,0,8">
                                <Run Text="{Binding SelectedCar.Year}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding SelectedCar.Mileage}"/>
                                <Run Text=" km"/>
                            </TextBlock>
                            <Button Content="Поменять машину"
                                    FontSize="11"
                                    Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SelectCarCommand}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Visibility="{Binding SelectedCar, Converter={StaticResource NullToVisInverse}}">
                            <TextBlock Text="Машина не выбрана"
                                       Foreground="{StaticResource HeaderText}"
                                       Opacity="0.5"
                                       FontSize="13"
                                       Margin="0,0,0,8"/>
                            <Button Content="Выбрать машину"
                                    FontSize="11"
                                    Padding="10,5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding SelectCarCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              Margin="12,0">
                    <StackPanel>
                        <TextBlock Text="ДОПОЛНИТЕЛЬНЫЕ ПАРАМЕТРЫ"
                                   Foreground="White"
                                   Opacity="0.5"
                                   FontSize="10"
                                   FontWeight="SemiBold"
                                   Margin="2,0,0,10"/>
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="auto"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0" Content="Использовать NHTSA"
                                          Foreground="White"
                                          IsChecked="{Binding UseNhtsa}"
                                          Margin="0 5"/>

                                <Button Grid.Column="1" MaxHeight="30" MaxWidth="30" Padding="0"
                                        Foreground="{StaticResource ButtonBack}"
                                        FontSize="16" Style="{StaticResource SymptomButton}"
                                        Content="ℹ️" Margin="0 0 20 0"
                                        Command="{Binding ShowWhatNhtsaIsCommand}"/>
                            </Grid>
                            <TextBlock Foreground="White" Opacity="0.5">
                                <Run Text="Количество записей:"></Run>
                                <Run Text="{Binding RecordsCount}"></Run>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="3" Margin="12,8,12,16" Background="{StaticResource SurfaceBack2}" Padding="5" CornerRadius="15">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Button Style="{StaticResource SymptomButton}"
                            Grid.Row="0"
                            Content="🗑  Очистить чат"
                            Padding="12 9"
                            Command="{Binding ClearChatCommand}"/>
                        <Button Grid.Row="1"
                                IsCancel="True"
                                Content="🏠 Назад в меню"
                                Padding="12 9"
                                Margin="0 10"
                                Command="{Binding BackHomePageCommand}"/>
                    </Grid>
                </Border>


            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#F5EFE6">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E0D5C8"
                    BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Диагностика ИИ специалиста"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource HeaderBack}"/>
                        <TextBlock FontSize="11" Foreground="#999">
                            <Run Text="ИИ модель"/>
                            <Run Text="{Binding ModelName}"
                                 Foreground="{StaticResource ButtonBack}"
                                 FontWeight="SemiBold"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Анализирую"
                                   Foreground="{StaticResource ButtonBack}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource ButtonBack}"
                                Margin="0,0,4,0">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="1" To="0.2" Duration="0:0:0.6"
                                                AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource ButtonBack}"
                                Margin="0,0,4,0">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="1" To="0.2" Duration="0:0:0.6"
                                                AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                        <Border Width="8" Height="8" CornerRadius="4"
                                Background="{StaticResource ButtonBack}">
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="Opacity"
                                                From="1" To="0.2" Duration="0:0:0.6"
                                                AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                
            <ScrollViewer 
                  x:Name="ChatScroll"
                  VerticalScrollBarVisibility="Auto"
                  Padding="20,16">
                <ItemsControl ItemsSource="{Binding Messages}"
                  ScrollViewer.VerticalScrollBarVisibility="Visible"
                  ScrollViewer.CanContentScroll="True">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,16">

                                <Border HorizontalAlignment="Right"
                                        MaxWidth="520"
                                        CornerRadius="16,16,4,16"
                                        Background="{StaticResource ButtonBack}"
                                        Padding="14,10"
                                        Visibility="{Binding IsUser, Converter={StaticResource BoolToVis}}">    
                                    <TextBlock Text="{Binding Message}"
                                               Foreground="White"
                                               FontSize="14"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <Border HorizontalAlignment="Left"
                                        MaxWidth="580"
                                        CornerRadius="16,16,16,4"
                                        Background="White"
                                        BorderBrush="#E8DDD0"
                                        BorderThickness="1"
                                        Padding="16,12">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource BoolAndToVisInverseConverter}">
                                            <Binding Path="IsDiagnosString"/>
                                            <Binding Path="IsUser"/>
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#C8A882"
                                              BlurRadius="8"
                                              ShadowDepth="2"
                                              Opacity="0.15"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="20" Height="20"
                                                    CornerRadius="10"
                                                    Background="{StaticResource MainBack}"
                                                    Margin="0,0,6,0">
                                                <TextBlock Text="⚙"
                                                           Foreground="{StaticResource ClueBack}"
                                                           FontSize="10"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding ModelName}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ClueBack}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Message}"
                                                   Foreground="#2D2D2D"
                                                   FontSize="14"
                                                   TextWrapping="Wrap"
                                                   LineHeight="22"/>
                                    </StackPanel>
                                </Border>

                                <Border HorizontalAlignment="Left"
                                        MaxWidth="580"
                                        CornerRadius="16,16,16,4"
                                        Background="White"
                                        BorderBrush="#E8DDD0"
                                        BorderThickness="1"
                                        Padding="16,14">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource BoolAndToVisConverter}">
                                            <Binding Path="IsDiagnosString"/>
                                            <Binding Path="IsUser"
                                                     Converter="{StaticResource BoolToVisInverse}"/>    
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#C8A882"
                                              BlurRadius="8"
                                              ShadowDepth="2"
                                              Opacity="0.15"/>
                                    </Border.Effect>
                                    <StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <Border Width="20" Height="20"
                                                    CornerRadius="10"
                                                    Background="{StaticResource MainBack}"
                                                    Margin="0,0,6,0">
                                                <TextBlock Text="⚙"
                                                           FontSize="10"
                                                           Foreground="{StaticResource ClueBack}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{Binding ModelName}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource ClueBack}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Border CornerRadius="10"
                                                Background="{StaticResource SurfaceBack2}"
                                                Padding="16,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="🔍 Диагноз готов"
                                                               FontSize="13"
                                                               FontWeight="Bold"
                                                               Foreground="White"/>
                                                    <TextBlock Text="Нажмите, чтобы просмотреть результат"
                                                               FontSize="11"
                                                               Foreground="#FFFFFF"
                                                               Opacity="0.65"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Content="Просмотреть диагноз"
                                                        Command="{Binding DataContext.ShowDiagnoseWindowCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="12,0,0,0"
                                                        Padding="14,8"
                                                        FontSize="12"
                                                        FontWeight="SemiBold"
                                                        Foreground="{StaticResource MainBack}"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bg"
                                                                    Background="White"
                                                                    CornerRadius="8"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <EventTrigger RoutedEvent="MouseEnter">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation Storyboard.TargetName="Bg"
                                                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                            To="#F0EBE3" Duration="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                                <EventTrigger RoutedEvent="MouseLeave">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation Storyboard.TargetName="Bg"
                                                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                            To="#FFFFFF" Duration="0:0:0.15"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                                <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <ColorAnimation Storyboard.TargetName="Bg"
                                                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                            To="#E0D8CE" Duration="0:0:0.08"/>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </EventTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
                <Border x:Name="MapLoadingOverlay"
                        Background="Transparent"
                        Visibility="{Binding IsHistoryNotExist,
                            Converter={StaticResource BoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📖"
                                   Foreground="{StaticResource SurfaceBack2}"
                                   FontSize="48"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,16"
                                   Opacity="0.5"/>
                        <TextBlock Text="История диалога пуста."
                                   FontSize="14"
                                   Foreground="#5A6279"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#E0D5C8"
                    BorderThickness="0,1,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="12"
                            Background="#F5EFE6"
                            BorderBrush="{StaticResource MainBack}"
                            BorderThickness="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="0.3*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="InputBox"
                                     Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="14,10"
                                     FontSize="14"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="False"
                                     MaxHeight="100"
                                     VerticalScrollBarVisibility="Auto"
                                     VerticalContentAlignment="Center"
                                     Foreground="#2D2D2D"/>

                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding AIModels.Keys}"
                                      SelectedItem="{Binding SelectedModel}"
                                      Margin="15 0"
                                      Padding="3"
                                      VerticalAlignment="Center"
                                      Foreground="{StaticResource ButtonBack}">
                            </ComboBox>

                            <TextBlock Grid.ColumnSpan="2"
                                       Text="Опишите проблему вашей машины..."
                                       Foreground="#BBAA99"
                                       FontSize="14"
                                       Margin="20,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding InputText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding InputText}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2"
                            IsDefault="True"
                            Width="48" Height="48"
                            Command="{Binding SendCommand}"
                            IsEnabled="{Binding IsNotLoading}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="SendBtn"
                                        Background="{StaticResource ButtonBack}"
                                        CornerRadius="12"
                                        Width="48" Height="48">
                                    <TextBlock Text="➤"
                                               Foreground="White"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation
                                                        Storyboard.TargetName="SendBtn"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#00B3B3" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation
                                                        Storyboard.TargetName="SendBtn"
                                                        Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                        To="#009999" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
