<Window x:Class="GearFix.Views.DialogViews.EditCarDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Title="{Binding Title}" Width="700">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBack}">
            <TextBlock Text="{Binding Title}"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="24,0"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
            <StackPanel Margin="24,20,24,10">

                <TextBlock Text="МАРКА" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding TextBoxMake, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="МОДЕЛЬ" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding TextBoxModel, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ГОД" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding TextBoxYear, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ПРОБЕГ (KM)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding TextBoxMileage, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="VIN ТРАНСПОРТА" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding TextBoxVin, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="ТИП ДВИГАТЕЛЯ" Style="{StaticResource FieldLabel}"/>
                <ComboBox SelectedItem="{Binding SelectedEngineType}"
                          ItemsSource="{Binding EngineTypes}"
                          Margin="0,0,0,16">
                </ComboBox>

                <TextBlock Text="ИЗОБРАЖЕНИЕ" Style="{StaticResource FieldLabel}"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             TextWrapping="NoWrap"
                             HorizontalScrollBarVisibility="Auto"
                             Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"/>

                    <Button Grid.Column="2"
                            Content="📁"
                            Width="82" Height="48"
                            Command="{Binding PickImageCommand}"
                            ToolTip="Выберите изображение машины"/>
                </Grid>

                <Border Height="auto" CornerRadius="10"
                        Background="#2A2A3E"
                        Margin="0,0,0,16"
                        ClipToBounds="True">
                    <Image Source="{Binding ImagePath, Converter={StaticResource ImageConv}}"
                           Stretch="UniformToFill"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <TextBlock Text="ДОПОЛНИТЕЛЬНАЯ ИНФОРМАЦИЯ" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding TextBoxAdditionalInfo, UpdateSourceTrigger=PropertyChanged}"
                         Height="80"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="НЕИСПРАВНОСТИ"
                               Style="{StaticResource FieldLabel}"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="+ Добавить"
                            Padding="14,6"
                            FontSize="12"
                            Command="{Binding AddMalfunctionCommand}"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Malfunctions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A2A3E"
                                    CornerRadius="8"
                                    Padding="12,10"
                                    Margin="0,0,0,8"
                                    BorderBrush="#1D7373"
                                    BorderThickness="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"/>
                                        <TextBlock Text="{Binding Date}"
                                                   Foreground="{StaticResource ClueBack}"
                                                   FontSize="11"
                                                   Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Content="✏️"
                                            Width="28" Height="28"
                                            Margin="0 0 8 0"
                                            Padding="0"
                                            Command="{Binding DataContext.EditMalfunctionCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Grid.Column="2"
                                            Content="🗑️"
                                            Width="28" Height="28"
                                            Style="{StaticResource DeleteButton}"
                                            Padding="0"
                                            Background="{StaticResource ErrorColor}"
                                            Command="{Binding DataContext.RemoveMalfunctionCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#12122A"
                BorderBrush="#1D7373"
                BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.5*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="3" Margin="5"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ErrorColor}"/>

                <Button IsCancel="True" Grid.Column="0" Grid.Row="1"
                        Content="Отмена"
                        MinHeight="70"
                        Margin="5"
                        Style="{StaticResource EditCancelButton}"
                        Command="{Binding CancelOperationCommand}"/>

                <Button IsDefault="True" Grid.Column="2" Grid.Row="1"
                        Content="{Binding ButtonContent}"
                        MinHeight="70"
                        Margin="5"
                        Background="{StaticResource ButtonBack}"
                        Command="{Binding ConfirmOperationCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>