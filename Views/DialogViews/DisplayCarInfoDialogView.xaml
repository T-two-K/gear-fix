<Window x:Class="GearFix.Views.DialogViews.DisplayCarInfoDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Title="Информация о транспортном средстве" Width="800" Height="750">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBack}" 
                BorderBrush="#1D7373" BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="White" FontSize="22" FontWeight="Bold">
                        <Run Text="{Binding Car.Make, FallbackValue='Марка'}"/>
                        <Run Text="{Binding Car.Model, FallbackValue='Модель'}"/>
                    </TextBlock>
                    <TextBlock Text="ДЕТАЛЬНЫЙ ПРОФИЛЬ ТРАНСПОРТНОГО СРЕДСТВА" 
                               Foreground="#5A6279" FontSize="11" FontWeight="SemiBold" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Border Height="240" CornerRadius="12" Background="#12122A" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="🚗" FontSize="64" HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" Opacity="0.15" Foreground="White"/>
                                <Image Source="{Binding Car.ImagePath, Converter={StaticResource ImageConv}}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <StackPanel Grid.Column="2" VerticalAlignment="Stretch">

                        <Border Background="#161B27" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ГОД ВЫПУСКА" FontSize="11" Foreground="#5A6279" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Car.Year, FallbackValue='2020'}" FontSize="18" Foreground="#EAEAEA" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#161B27" CornerRadius="8" Padding="16,12" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ТЕКУЩИЙ ПРОБЕГ" FontSize="11" Foreground="#5A6279" FontWeight="Bold"/>
                                <TextBlock FontSize="18" Foreground="#EAEAEA" FontWeight="SemiBold" Margin="0,4,0,0">
                                    <Run Text="{Binding Car.Mileage, FallbackValue='0'}"/>
                                    <Run Text=" км" Foreground="#5A6279" FontSize="14"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#161B27" CornerRadius="8" Padding="16,12">
                            <StackPanel>
                                <TextBlock Text="ТИП ДВИГАТЕЛЯ" FontSize="11" Foreground="#5A6279" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Car.EngineType, FallbackValue='Не указан'}"
                                           FontSize="16" Foreground="#5CCCCC" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="#161B27" CornerRadius="8" Padding="16,12" Margin="0,16,0,16">
                    <Grid>
                        <StackPanel>
                            <TextBlock Text="ИДЕНТИФИКАЦИОННЫЙ НОМЕР (VIN)" FontSize="11" Foreground="#5A6279" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Car.Vin, FallbackValue='XTA00000000000000'}" 
                                       FontSize="16" Foreground="White" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="#1D7373" CornerRadius="4" Padding="8,4"
                                Visibility="{Binding Car.Vin, Converter={StaticResource NullToVis}}">
                            <TextBlock Text="ПРИНЯТ" FontSize="10" Foreground="White" FontWeight="Bold"/>
                        </Border>
                    </Grid>
                </Border>

                <TextBlock Text="ДОПОЛНИТЕЛЬНЫЕ СВЕДЕНИЯ" Style="{StaticResource FieldLabel}" Margin="0,0,0,6"/>
                <Border Background="#12122A" CornerRadius="8" Padding="16" BorderBrush="#1E2435" BorderThickness="1" Margin="0,0,0,24">
                    <TextBlock Text="{Binding Car.AdditionalInfo, FallbackValue='Дополнительная информация отсутствует.'}" 
                               Foreground="#B2B8C9" FontSize="13" TextWrapping="Wrap" LineHeight="18"/>
                </Border>

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="ЖУРНАЛ НЕИСПРАВНОСТЕЙ" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                    <Border Background="#FF4C4C" CornerRadius="10" HorizontalAlignment="Right" Padding="8,2" Visibility="{Binding HasMalfunctions, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="ТРЕБУЕТ ВНИМАНИЯ" FontSize="10" Foreground="White" FontWeight="Bold"/>
                    </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding Car.Malfunctions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#2A2A3E" CornerRadius="8" Padding="16,14" Margin="0,0,0,8" 
                                    BorderBrush="#1D7373" BorderThickness="3,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="14"/>
                                        <TextBlock Text="{Binding Description}" Foreground="#B2B8C9" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0" LineHeight="16"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding Date}" Foreground="#5A6279" FontSize="11" HorizontalAlignment="Right"/>
                                        <Border CornerRadius="4" Padding="6,3" Margin="0,6,0,0" Background="#1A1A2E">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Опасность: " FontSize="10" Foreground="#5A6279"/>
                                                <TextBlock Text="{Binding Danger}" FontSize="11" FontWeight="Bold"
                                                           Foreground="{Binding Danger, Converter={StaticResource DangerToColor}}"/>
                                                <TextBlock Text="%" FontSize="9"
                                                           Foreground="{Binding Danger, Converter={StaticResource DangerToColor}}"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#12122A" BorderBrush="#1D7373" BorderThickness="0,1,0,0" Padding="0,12">
            <Grid Margin="24,0">
                <Button IsCancel="True" Content="Закрыть профиль" 
                        HorizontalAlignment="Right"
                        Width="180" MinHeight="45"
                        Command="{Binding CloseCommand}"
                        Background="{StaticResource ButtonBack}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
