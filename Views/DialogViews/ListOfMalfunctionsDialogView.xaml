<Window x:Class="GearFix.Views.DialogViews.ListOfMalfunctionsDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        Title="ListOfMalfunctionsDialogView" MaxHeight="1000" Width="1000"
        SizeToContent="Height" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="MalfunctionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#161B27"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.35"
                                      BlurRadius="12" ShadowDepth="2" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProbabilityBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#252B3A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
                            <Border x:Name="PART_Track" CornerRadius="2"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    HorizontalAlignment="Left"
                                    CornerRadius="2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="MalfunctionCardTemplate">
            <Border Style="{StaticResource MalfunctionCardStyle}">
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                 To="4" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                 To="0" Duration="0:0:0.15"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Border.RenderTransform>
                    <TranslateTransform X="0"/>
                </Border.RenderTransform>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                    CornerRadius="6,0,0,6"
                    Background="{Binding Danger, Converter={StaticResource DangerToColor}}"/>

                    <Grid Grid.Column="1" Margin="16,14,16,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- ── Строка 0: заголовок + кнопка подробнее ── -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                               Text="{Binding Title}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#EAEAEA"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>

                            <Button Grid.Column="1"
                                    Content="Подробнее →"
                                    Command="{Binding DataContext.MoreInfoCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                    CommandParameter="{Binding}"
                                    Cursor="Hand"
                                    Margin="10,0,0,0"
                                    Padding="10,4"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="#5CCCCC"
                                    Background="Transparent"
                                    BorderBrush="#1C7C7C"
                                    BorderThickness="1">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Btn"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Btn" Property="Background" Value="#1C7C7C"/>
                                                            <Setter TargetName="Btn" Property="BorderBrush" Value="#5CCCCC"/>
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Btn" Property="Background" Value="#145C5C"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>

                        <!-- ── Строка 2: описание + бейдж опасности ── -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                               Text="{Binding MalfunctionDescription}"
                               FontSize="12.5"
                               Foreground="#8E98B0"
                               TextWrapping="Wrap"
                               MaxHeight="52"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,12,0"/>

                            <Border Grid.Column="1"
                            Background="{Binding Danger, Converter={StaticResource DangerToColor}}"
                            CornerRadius="4"
                            Padding="9,4"
                            VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⚠ " FontSize="11" Foreground="#0F1117"/>
                                    <TextBlock Text="{Binding Danger, StringFormat='{}{0}/100'}"
                                       FontSize="11"
                                       FontWeight="Bold"
                                       Foreground="#0F1117"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- ── Строка 4: прогресс-бар ── -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                               Text="Вероятность"
                               FontSize="11"
                               Foreground="#009999"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>

                            <ProgressBar Grid.Column="1"
                                 Style="{StaticResource ProbabilityBarStyle}"
                                 Foreground="#009999"
                                 Value="{Binding Probability}"
                                 Minimum="0" Maximum="100"
                                 VerticalAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                               Text="{Binding Probability, StringFormat='{}{0}%'}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#5CCCCC"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F1117" Padding="24,18,24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="ДИАГНОСТИКА"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="#A64B00"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Обнаруженные неисправности"
                               FontSize="22"
                               FontWeight="Light"
                               Foreground="#E8E8E8"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#1D2130"
                        CornerRadius="8"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Malfunctions.Count}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#FFB273"/>
                        <TextBlock Text=" найдено"
                                   FontSize="13"
                                   Foreground="#5A6279"
                                   VerticalAlignment="Bottom"
                                   Margin="2,0,0,1"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="1" Fill="#1E2435"
                   VerticalAlignment="Bottom"/>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Malfunctions}"
                 ItemTemplate="{StaticResource MalfunctionCardTemplate}"
                 SelectedItem="{Binding SelectedMalfunction}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 Padding="24,20,24,20" >
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <!-- Этот Border оборачивает ContentPresenter и является SelectionGlow -->
                                <Border x:Name="SelectionGlow"
                            Background="Transparent"
                            CornerRadius="6">
                                    <Border.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Border.RenderTransform>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#1C7C7C"
                                              Opacity="0"
                                              BlurRadius="0"
                                              ShadowDepth="0"/>
                                    </Border.Effect>
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SelectionGlow"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                        To="8" Duration="0:0:0.2"/>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SelectionGlow"
                                                        Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                        To="1" Duration="0:0:0.2"/>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SelectionGlow"
                                                        Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)"
                                                        To="15" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SelectionGlow"
                                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                        To="0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SelectionGlow"
                                                        Storyboard.TargetProperty="(Effect).(DropShadowEffect.Opacity)"
                                                        To="0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation
                                                        Storyboard.TargetName="SelectionGlow"
                                                        Storyboard.TargetProperty="(Effect).(DropShadowEffect.BlurRadius)"
                                                        To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Button IsCancel="True" Grid.Column="0" Style="{StaticResource CancelButton}"
                    Content="Закрыть окно" FontSize="20" MinHeight="70"
                    MaxWidth="250" Margin="10" Command="{Binding CancelCommand}"/>

            <Button IsDefault="True" Grid.Column="1" Content="Подтвердить выбор" FontSize="20" MinHeight="70"
                    MaxWidth="250" Margin="10" Command="{Binding ConfirmCommand}"/>
        </Grid>
    </Grid>
</Window>
