<Window x:Class="GearFix.Views.DialogViews.EditMalfunctionDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Title="{Binding Title}" Width="550" Height="520">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBack}">
            <TextBlock Text="{Binding Title}"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="24,0"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,10">

                <TextBlock Text="НАЗВАНИЕ НЕИСПРАВНОСТИ" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding MalfunctionTitle, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,16"/>

                <TextBlock Text="ДАТА ОБНАРУЖЕНИЯ" Style="{StaticResource FieldLabel}"/>
                <DatePicker SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"
                            Margin="0,0,0,16"/>

                <Grid Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="УРОВЕНЬ ОПАСНОСТИ" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Danger, StringFormat={}{0}/100}"
                               Foreground="{Binding Danger, Converter={StaticResource DangerToColor}}"
                               FontWeight="Bold" FontSize="14" VerticalAlignment="Bottom"/>

                    <Slider Grid.Row="1" Grid.ColumnSpan="2"
                            Value="{Binding Danger, UpdateSourceTrigger=PropertyChanged}" 
                            Minimum="1" Maximum="100"
                            TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Margin="0,6,0,0"/>
                </Grid>

                <TextBlock Text="ПОДРОБНОЕ ОПИСАНИЕ" Style="{StaticResource FieldLabel}"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="120"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="#12122A"
                BorderBrush="#1D7373"
                BorderThickness="0,1,0,0">
            <Grid Margin="24,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.ColumnSpan="3" Margin="5"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource ErrorColor}"/>

                <Button IsCancel="True" Grid.Column="0" Grid.Row="1"
                        Content="Отмена"
                        MinHeight="50"
                        Margin="5"
                        Style="{StaticResource EditCancelButton}"
                        Command="{Binding CancelCommand}"/>

                <Button IsDefault="True" Grid.Column="2" Grid.Row="1"
                        Content="{Binding ButtonContent}"
                        MinHeight="50"
                        Margin="5"
                        Background="{StaticResource ButtonBack}"
                        Command="{Binding ConfirmCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
