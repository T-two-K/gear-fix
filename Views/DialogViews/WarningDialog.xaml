<Window x:Class="GearFix.Views.DialogViews.WarningDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        Height="250" Width="400">
    <Border CornerRadius="20" BorderThickness="2" BorderBrush="{StaticResource HeaderBack}"
            Background="{StaticResource ButtonDisabledText}">
        <Grid Background="{StaticResource ButtonDisabledText}" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.5*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="0.5*"></RowDefinition>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{Binding Title}"
                   TextAlignment="Center" VerticalAlignment="Center"
                   FontSize="25" FontWeight="Bold"
                   Foreground="{StaticResource ErrorColor}" d:Text="Warning!"/>
            <Border Grid.Row="1" Background="Bisque" Margin="-5 0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <TextBlock Text="{Binding WarningContent}"
                               TextAlignment="Center"
                               FontSize="18"
                               TextWrapping="Wrap"
                               Padding="10,5"
                               d:Text="Something happened. This is a very long text to test how the scroll viewer works when content overflows the window boundaries.
                               But it is very short, so I had to write something to fill this gap."/>
                </ScrollViewer>
            </Border>

            <Grid Grid.Row="2" Margin="0 3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Button IsCancel="True" Grid.Column="0" Command="{Binding CancelCommand}"
                        Margin="10 0" Content="Отмена"
                        Style="{StaticResource CancelButton}">
                </Button>
                <Button IsDefault="True" Grid.Column="1" Command="{Binding ConfirmCommand}"
                    Margin="10 0" Content="{Binding ButtonContent}" d:Content="Подтвердить"></Button>
            </Grid>
        </Grid>
    </Border>
</Window>