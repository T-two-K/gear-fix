<Window x:Class="GearFix.Views.DialogViews.ChangePasswordDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        Height="480" Width="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#1C1C2E"
            BorderBrush="#A64B00"
            BorderThickness="1.5"
            CornerRadius="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0"
                    Background="{StaticResource HeaderBack}"
                    CornerRadius="14,14,0,0"
                    Padding="20,14">
                <Grid>
                    <TextBlock Text="Смена пароля"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    
                    <Button Content="✕"
                            HorizontalAlignment="Right"
                            Width="28" Height="28"
                            Foreground="White"
                            Background="Transparent"
                            BorderThickness="0"
                            FontSize="13"
                            Cursor="Hand"
                            Command="{Binding CloseCommand}">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Padding="4">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#55FFFFFF"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>

            <!-- Поля ввода -->
            <StackPanel Grid.Row="1" Margin="24,24,24,8" VerticalAlignment="Center">

                <!-- Текущий пароль -->
                <TextBlock Text="Текущий пароль"
                           Foreground="#9999BB"
                           FontSize="12"
                           Margin="4,0,0,6"/>
                <Border Background="#2A2A3E"
                        BorderBrush="#3A3A55"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,16">
                    <Grid>
                        <TextBox x:Name="CurrentPassword"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     MaxHeight="50"
                                     CaretBrush="White"
                                     FontSize="14"
                                     Text="{Binding CurrentPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Введите текущий пароль"
                                   VerticalAlignment="Center"
                                   Foreground="#55667788"
                                   MaxHeight="50"
                                   FontSize="14"
                                   Padding="14,10"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPassword}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding CurrentPassword}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Новый пароль -->
                <TextBlock Text="Новый пароль"
                           Foreground="#9999BB"
                           FontSize="12"
                           Margin="4,0,0,6"/>
                <Border Background="#2A2A3E"
                        BorderBrush="#3A3A55"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,16">
                    <Grid>
                        <TextBox x:Name="NewPassword"
                                     MaxHeight="50"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     CaretBrush="White"
                                     FontSize="14"
                                     Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Введите новый пароль"
                                   Foreground="#55667788"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Padding="14,10"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding NewPassword}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding NewPassword}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Подтверждение нового пароля -->
                <TextBlock Text="Подтвердите новый пароль"
                           Foreground="#9999BB"
                           FontSize="12"
                           Margin="4,0,0,6"/>
                <Border Background="#2A2A3E"
                        BorderBrush="#3A3A55"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <TextBox x:Name="ConfirmPassword"
                                     MaxHeight="50"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     CaretBrush="White"
                                     FontSize="14"
                                     Text="{Binding ConfirmPassword, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="Повторите новый пароль"
                                   Foreground="#55667788"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Padding="14,10"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ConfirmPassword}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ConfirmPassword}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

            </StackPanel>

            <Border Grid.Row="2" Margin="24,8,24,24">
                <Button IsDefault="True" Content="Подтвердить"
                        Height="42"
                        Command="{Binding ConfirmCommand}"/>
            </Border>

        </Grid>
    </Border>
</Window>
