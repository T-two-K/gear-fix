<Window x:Class="GearFix.Views.DialogViews.SelectCarDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GearFix.Views.DialogViews"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Height="560" Width="780">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource HeaderBack}">
            <Grid Margin="24,0">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Выберите авто"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Нажмите на карточку, чтобы выбрать"
                               Foreground="White"
                               Opacity="0.5"
                               FontSize="11"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <TextBlock HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Opacity="0.5"
                           FontSize="12">
                    <Run Text="{Binding Cars.Count, Mode=OneWay}"/>
                    <Run Text=" доступно автомобилей"/>
                </TextBlock>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="16,16,16,0">
            <ItemsControl ItemsSource="{Binding Cars}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="CardBorder"
                                Width="210"
                                Margin="0,0,12,12"
                                CornerRadius="14"
                                Background="White"
                                BorderBrush="#E8DDD0"
                                BorderThickness="1"
                                Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5">

                            <Border.RenderTransform>
                                <TranslateTransform x:Name="CardTranslate" Y="0"/>
                            </Border.RenderTransform>

                            <Border.Effect>
                                <DropShadowEffect x:Name="CardShadow"
                                                  Color="#C8A882"
                                                  BlurRadius="8"
                                                  ShadowDepth="3"
                                                  Opacity="0.2"/>
                            </Border.Effect>

                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.SelectCarCommand,
                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="-6" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="20" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.4" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="CardBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#009999" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="Border.MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="8" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.2" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="CardBorder"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#E8DDD0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="110"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Изображение -->
                                <Border Grid.Row="0"
                                        CornerRadius="14,14,0,0"
                                        Background="{StaticResource SurfaceBack2}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <TextBlock Text="🚗" FontSize="36"
                                                   Foreground="{StaticResource ClueBack}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Opacity="0.5"/>
                                        <Image Source="{Binding ImagePath, Converter={StaticResource ImageConv}}"
                                               Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>

                                <!-- Инфо -->
                                <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                    <TextBlock FontSize="15" FontWeight="Bold" Foreground="#2D2D2D">
                                        <Run Text="{Binding Make}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Model}"/>
                                    </TextBlock>

                                    <TextBlock FontSize="12" Foreground="#888" Margin="0,3,0,6">
                                        <Run Text="{Binding Year}"/>
                                        <Run Text=" · "/>
                                        <Run Text="{Binding Mileage}"/>
                                        <Run Text=" km"/>
                                    </TextBlock>

                                    <Border CornerRadius="4"
                                            Padding="8,3"
                                            Background="Transparent"
                                            BorderBrush="#009999"
                                            BorderThickness="1"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,12"
                                            Visibility="{Binding EngineType,
                                                Converter={StaticResource NullToVis}}">
                                        <TextBlock Text="{Binding EngineType}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="#5CCCCC"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="White"
                BorderBrush="Bisque"
                BorderThickness="0,1,0,0">
            <Grid Margin="24,0">
                <Button IsCancel="True" Content="Отмена"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Padding="35,15"
                        Style="{StaticResource EditCancelButton}"
                        Command="{Binding CancelCommand}"/>
            </Grid>
        </Border>
    </Grid>
</Window>
